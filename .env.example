# Your One secret key (get from app.withone.ai → Settings → API Keys)
ONE_SECRET=sk_live_your_key_here

# Anthropic API key for Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Public URL of this app (needed for webhook relay callbacks)
# Use ngrok for local dev — localhost won't work for webhooks
NEXT_PUBLIC_APP_URL=https://your-subdomain.ngrok-free.dev

# Identity for connection scoping (optional)
ONE_IDENTITY=dev-pulse-user
ONE_IDENTITY_TYPE=user

# Signing secret for webhook relay verification (optional)
WEBHOOK_RELAY_SECRET=
